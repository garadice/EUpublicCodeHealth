# ── Database ──────────────────────────────────────────────
# For local development (host-to-Docker):
DATABASE_URL=postgresql+psycopg://eupublicode:eupublicode@localhost:5434/eupublicode
# For Docker Compose (containers use db:5432, set automatically in docker-compose.yml)
POSTGRES_DB=eupublicode
POSTGRES_USER=eupublicode
POSTGRES_PASSWORD=eupublicode

# ── GitHub API ────────────────────────────────────────────
# Generate a token at: https://github.com/settings/tokens
# Required scope: public_repo
GITHUB_TOKEN=

# ── API Authentication ────────────────────────────────────
# Set to a random string to enable API key auth on /api/* and /exports/*.
# Leave empty to disable auth (local development mode).
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=

# ── Developers Italia API ─────────────────────────────────
# Base URL for the catalogue API (must use HTTPS)
# DEVELOPERS_ITALIA_BASE_URL=https://api.developers.italia.it/v1/software

# ── CORS ──────────────────────────────────────────────────
# JSON array of allowed origins for the API
# ALLOWED_ORIGINS=["http://localhost:8501"]

# ── Scheduler ─────────────────────────────────────────────
# Interval between automatic pipeline runs (seconds)
INGEST_INTERVAL_SECONDS=86400

# ── Application ───────────────────────────────────────────
DEBUG=false
